<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="edu.hznu.forest.mapper.OperationLogMapper">

    <resultMap id="operationLogResultMap" type="edu.hznu.forest.entity.OperationLog">
        <id property="logId" column="log_id"/>
        <result property="userId" column="user_id"/>
        <result property="operation" column="operation"/>
        <result property="operationTime" column="operation_time"/>
        <result property="details" column="details"/>
    </resultMap>

    <select id="findAll" resultMap="operationLogResultMap">
        SELECT * FROM operation_log ORDER BY operation_time DESC
    </select>

    <select id="findByUserId" resultMap="operationLogResultMap">
        SELECT * FROM operation_log WHERE user_id = #{userId}
    </select>

    <select id="findByTimeRange" resultMap="operationLogResultMap">
        SELECT * FROM operation_log
        WHERE operation_time BETWEEN #{start} AND #{end}
        ORDER BY operation_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="logId">
        INSERT INTO operation_log (user_id, operation, operation_time, details)
        VALUES (#{userId}, #{operation}, #{operationTime}, #{details})
    </insert>

</mapper>
