<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="edu.hznu.forest.mapper.ModelMapper">

    <resultMap id="modelResultMap" type="edu.hznu.forest.entity.Model">
        <id property="modelId" column="model_id"/>
        <result property="modelName" column="model_name"/>
        <result property="algorithm" column="algorithm"/>
        <result property="trainDate" column="train_date"/>
        <result property="rSquared" column="r_squared"/>
        <result property="rmse" column="rmse"/>
        <result property="featureList" column="feature_list"/>
        <result property="description" column="description"/>
    </resultMap>

    <select id="findAll" resultMap="modelResultMap">
        SELECT * FROM model
    </select>

    <select id="findById" resultMap="modelResultMap">
        SELECT * FROM model WHERE model_id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="modelId">
        INSERT INTO model (model_name, algorithm, train_date, r_squared, rmse, feature_list, description)
        VALUES (#{modelName}, #{algorithm}, #{trainDate}, #{rSquared}, #{rmse}, #{featureList}, #{description})
    </insert>

    <update id="update">
        UPDATE model
        SET model_name = #{modelName},
            algorithm = #{algorithm},
            train_date = #{trainDate},
            r_squared = #{rSquared},
            rmse = #{rmse},
            feature_list = #{featureList},
            description = #{description}
        WHERE model_id = #{modelId}
    </update>

    <delete id="delete">
        DELETE FROM model WHERE model_id = #{id}
    </delete>

</mapper>
